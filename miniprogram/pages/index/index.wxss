/* 浅色模式默认变量 */ page { --bg-color: #f5f7fa; --header-bg: #1677ff; --text-color: #333333; --ai-bubble-bg: #ffffff; --input-bg: #ffffff; --border-color: #eeeeee; background: var(--bg-color); font-size: 30rpx; transition: all 0.3s ease; } /* 深色模式变量（关键！） */ page.dark { --bg-color: #111111; --header-bg: #222831; --text-color: #eeeeee; --ai-bubble-bg: #2d3440; --input-bg: #252a34; --border-color: #333333; } .header{ position:fixed; top:0; left:0; right:0; height:90rpx; background: var(--header-bg); display:flex; align-items:center; justify-content:center; z-index:99; } .title{ color:#fff; font-size:36rpx; font-weight:bold; } .header-right { position:absolute; right:20rpx; display:flex; gap:16rpx; } .theme-btn { width: 60rpx; height: 60rpx; border-radius: 50%; background: rgba(255,255,255,0.2); color:#fff; font-size:28rpx; line-height:60rpx; padding:0; margin:0; } .clear-btn{ background:rgba(255,255,255,0.2); color:#fff; font-size:26rpx; border-radius:30rpx; line-height:60rpx; padding:0 20rpx; margin:0; } /* 聊天容器：浅色/深色背景切换 */ .chat-container{ position:fixed; top:90rpx; bottom:120rpx; left:0; right:0; padding:20rpx; background: var(--bg-color); } .chat-list{ display:flex; flex-direction:column; gap:24rpx; } .chat-item{ display:flex; align-items:flex-start; gap:16rpx; } .chat-item.user{ flex-direction:row-reverse; } /* 头像：深色模式适配 */ .avatar{ width:72rpx; height:72rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; background:#e8f3ff; } /* 关键：深色模式下头像变色 */ .dark .avatar{ background:#393e46; color:#fff; } /* 气泡：深色模式适配 */ .bubble{ max-width:72%; padding:24rpx; border-radius:20rpx; line-height:1.6; } .ai-bubble{ background: var(--ai-bubble-bg); color: var(--text-color); border-top-left-radius:0; } .user-bubble{ background:#1677ff; color:#fff; border-top-right-radius:0; } /* 输入区域：深色模式适配 */ .input-area{ position:fixed; bottom:0; left:0; right:0; height:120rpx; background: var(--ai-bubble-bg); display:flex; align-items:center; padding:0 20rpx; border-top:1rpx solid var(--border-color); } .input{ flex:1; height:76rpx; background: var(--input-bg); border-radius:40rpx; padding:0 30rpx; color: var(--text-color); } .send-btn{ width:110rpx; height:76rpx; line-height:76rpx; background:#1677ff; color:#fff; border-radius:40rpx; margin-left:16rpx; font-size:28rpx; } .send-btn[disabled]{ background:#699ce6; }