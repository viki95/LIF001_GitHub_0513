<view class="header"> <text class="title">AI理财助手</text> <view class="header-right"> <button class="theme-btn" bindtap="toggleTheme"> {{isDark ? '☀️' : '🌙'}} </button> <button class="clear-btn" bindtap="clearChat">清空</button> </view> </view> <!-- 关键：给scroll-view加上深色模式类名绑定 --> <scroll-view class="chat-container" wx:class="{{isDark ? 'dark' : ''}}" scroll-y scroll-top="{{scrollTop}}"> <view class="chat-list"> <view class="chat-item ai"> <view class="avatar ai-avatar">🤖</view> <view class="bubble ai-bubble"> 你好～我是大学生理财助手，有理财问题都可以问我😊 </view> </view> <view class="chat-item {{item.role=='user'?'user':'ai'}}" wx:for="{{chatList}}" wx:key="index"> <view class="avatar {{item.role=='user'?'user-avatar':'ai-avatar'}}"> {{item.role=='user'?'我':'🤖'}} </view> <view class="bubble {{item.role=='user'?'user-bubble':'ai-bubble'}}"> {{item.content}} </view> </view> <view class="chat-item ai" wx:if="{{loading}}"> <view class="avatar ai-avatar">🤖</view> <view class="bubble ai-bubble loading">思考中...</view> </view> </view> </scroll-view> <!-- 关键：给input-area加上深色模式类名绑定 --> <view class="input-area" wx:class="{{isDark ? 'dark' : ''}}"> <input class="input" placeholder="输入你的理财问题..." value="{{question}}" bindinput="onInput" /> <button class="send-btn" bindtap="sendMsg" disabled="{{loading}}">发送</button> </view>